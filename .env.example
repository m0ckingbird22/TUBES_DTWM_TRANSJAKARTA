# ============================================
# Environment Variables - Tubes DWH Jakarta
# ============================================
# Copy file ini menjadi .env → cp .env.example .env
# Lalu isi nilai aslinya. File .env sudah di-gitignore.

# Google Cloud
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_APPLICATION_CREDENTIALS=credentials.json

# Google Maps Places API
GOOGLE_MAPS_API_KEY=your-api-key-here

# BigQuery
BQ_DATASET=jakarta_transit_dwh
BQ_LOCATION=asia-southeast2
